# Extraer el año de la columna 'Date' (asumiendo que está en formato 'YYYY-MM-DD')
# Si ya tienes la columna como datetime, puedes usar dt.year. Pero aquí usaremos split.
def extract_year(date_series):
    years = []
    for date in date_series:
        # Si es string, dividir por '-'
        if isinstance(date, str):
            years.append(int(date.split('-')[0]))
        else:
            # Si es datetime, usar .year
            years.append(date.year)
    return years

# Aplicar la función para crear una nueva columna 'Year'
